{
  "name": "rate-limiter",
  "version": "1.0.0",
  "description": "A configurable rate limiter service with multiple algorithms",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "migrate": "tsx db/migrations/run.ts",
    "seed": "tsx db/seeds/run.ts",
    "test": "jest --detectOpenHandles"
  },
  "keywords": [
    "rate-limiter",
    "fastify",
    "redis",
    "postgres"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/postgres": "^6.0.0",
    "@fastify/redis": "^7.0.0",
    "@fastify/static": "^9.0.0",
    "ajv": "^8.17.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@vercel/node": "^5.6.18",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
